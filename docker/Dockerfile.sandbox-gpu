# ML Research Sandbox — GPU variant (requires nvidia-container-toolkit)
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3-pip build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir \
    torch torchvision torchaudio \
    scikit-learn numpy pandas matplotlib seaborn \
    xgboost lightgbm optuna tqdm joblib

RUN mkdir -p /workspace /results
WORKDIR /workspace

RUN useradd -m -u 1000 researcher && \
    chown -R researcher:researcher /workspace /results
USER researcher

CMD ["python3", "/workspace/experiment.py"]
